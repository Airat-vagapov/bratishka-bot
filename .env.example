# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Таймаут запроса к OpenRouter в миллисекундах
OPENROUTER_REQUEST_TIMEOUT=30000
# Необязательно: сайт-реферер для статистики OpenRouter
# OPENROUTER_REFERER=https://github.com/yourname/bratishka-bot

# Настройки бота
# Через сколько сообщений активный наблюдатель анализирует чат
OBSERVER_INTERVAL=10
# Сколько последних сообщений отправляет observer в AI
OBSERVER_CONTEXT_LIMIT=10
# Минимальный интервал между observer-запросами в одном чате (мс)
OBSERVER_MIN_INTERVAL_MS=30000
# Максимальное количество сообщений в истории чата (хранится в файле history.json)
MAX_HISTORY=200
# Сколько последних сообщений отправлять ИИ при упоминании/ответе
HISTORY_CONTEXT_LIMIT=30
# Интервал сохранения истории на диск (мс)
HISTORY_SAVE_INTERVAL_MS=5000
# Опционально: username бота (если не указан, определится автоматически)
BOT_USERNAME=
# Максимальная длина сообщения в Telegram (4096 символов). Обрезает и входящие сообщения, и ответы бота.
MAX_MESSAGE_LENGTH=4096
# Максимальное число токенов в ответе от AI. Должно хватать на MAX_MESSAGE_LENGTH символов.
OPENROUTER_MAX_TOKENS=4096
# Окно rate limit (мс)
RATE_LIMIT_WINDOW_MS=60000
# Максимальное количество AI-запросов от одного пользователя в окне rate limit
RATE_LIMIT_MAX_REQUESTS=10

# Логирование входящих сообщений и запросов к ИИ
DEBUG=false
